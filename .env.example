# --- Octopus Energy credentials -------------------------------------------
# API key: octopus.energy dashboard -> Personal details -> Developer settings.
# The key grants full READ access to your account — never commit it.
OCTOPUS_API_KEY=
# Account number, looks like A-XXXXXXXX (top of any bill).
OCTOPUS_ACCOUNT_NUMBER=

# --- Billing accuracy -------------------------------------------------------
# DIRECT_DEBIT or NON_DIRECT_DEBIT — variable tariffs price these differently.
OCTOPUS_PAYMENT_METHOD=DIRECT_DEBIT
# From a gas bill (MJ/m3). Only used for SMETS2 meters reporting m3.
GAS_CALORIFIC_VALUE=39.5
# auto | kwh | m3  (SMETS1 reports kWh, SMETS2 reports m3; auto infers once)
GAS_UNIT=auto

# --- Home Mini (optional) ---------------------------------------------------
# EUI64 device id, e.g. 12-34-5A-FF-FF-6B-C7-89. Leave empty to auto-discover;
# telemetry stays dormant until a device exists on the account.
HOME_MINI_DEVICE_ID=

# --- App --------------------------------------------------------------------
ENERGY_DB_PATH=data/energy.db
# Set to 1 to run entirely on deterministic synthetic data (no credentials).
ENERGY_MOCK=
